<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NVLite.App.Views.DriverPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Driver Management" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="600" HorizontalAlignment="Left">

                <!-- Installed Driver Info -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Installed Driver" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock>
                            <Run Text="Version: " Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Run Text="{x:Bind ViewModel.InstalledVersion, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Latest Driver Info -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Latest Available" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock>
                            <Run Text="Version: " Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <Run Text="{x:Bind ViewModel.LatestVersion, Mode=OneWay}" FontWeight="SemiBold" />
                        </TextBlock>
                        <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    </StackPanel>
                </Border>

                <!-- Actions -->
                <StackPanel Spacing="8">
                    <Button Content="Check for Updates"
                            Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                            Style="{StaticResource AccentButtonStyle}" />

                    <ProgressBar Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}"
                                 Maximum="100"
                                 Visibility="{x:Bind ViewModel.IsDownloading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                    <Button Content="Download Driver"
                            Command="{x:Bind ViewModel.DownloadDriverCommand}" />
                </StackPanel>

                <!-- Options -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Install Options" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <CheckBox Content="Clean install"
                                  IsChecked="{x:Bind ViewModel.CleanInstall, Mode=TwoWay}" />
                        <CheckBox Content="Clear shader cache"
                                  IsChecked="{x:Bind ViewModel.ClearShaderCache, Mode=TwoWay}" />
                        <Button Content="Launch Installer"
                                Command="{x:Bind ViewModel.LaunchInstallerCommand}" />
                    </StackPanel>
                </Border>

                <!-- Status -->
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
