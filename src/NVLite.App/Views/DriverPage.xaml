<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NVLite.App.Views.DriverPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:drivers="using:NVLite.Core.Drivers"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Driver Management" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,16" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16" MaxWidth="700" HorizontalAlignment="Left">

                <!-- Driver Status (merged: installed + latest) -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Driver Status" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="4">
                                <TextBlock Text="Installed" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.InstalledVersion, Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="18" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="4">
                                <TextBlock Text="Latest Available" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBlock Text="{x:Bind ViewModel.LatestVersion, Mode=OneWay}"
                                           FontWeight="SemiBold" FontSize="18" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="{x:Bind ViewModel.UpdateStatus, Mode=OneWay}"
                                   Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                        <Button Content="Check for Updates"
                                Command="{x:Bind ViewModel.CheckForUpdatesCommand}"
                                Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                </Border>

                <!-- Download & Install -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Download &amp; Install" Style="{StaticResource SubtitleTextBlockStyle}" />

                        <!-- Download button (hidden while downloading or installing) -->
                        <Button Content="Download Latest Driver"
                                Command="{x:Bind ViewModel.DownloadDriverCommand}"
                                Visibility="{x:Bind ViewModel.IsDownloading, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}" />

                        <!-- Download progress -->
                        <StackPanel Spacing="4"
                                    Visibility="{x:Bind ViewModel.IsDownloading, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ProgressBar Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}"
                                             Maximum="100" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.DownloadSizeText, Mode=OneWay}"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                <Button Grid.Column="2" Content="Cancel"
                                        Command="{x:Bind ViewModel.CancelDownloadCommand}" />
                            </Grid>
                        </StackPanel>

                        <!-- Downloaded file indicator -->
                        <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                CornerRadius="6" Padding="12,8"
                                Visibility="{x:Bind ViewModel.HasDownloadedDriver, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Spacing="4">
                                <TextBlock Text="&#xE73E;  Driver ready to install" FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind ViewModel.DownloadedDriverPath, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           IsTextSelectionEnabled="True" />
                            </StackPanel>
                        </Border>

                        <!-- Install options (shown when driver is downloaded) -->
                        <StackPanel Spacing="10"
                                    Visibility="{x:Bind ViewModel.HasDownloadedDriver, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">

                            <!-- Install mode -->
                            <TextBlock Text="Install Mode" FontWeight="SemiBold" Margin="0,4,0,0" />
                            <RadioButton Content="Minimal (Recommended)"
                                         IsChecked="{x:Bind ViewModel.UseMinimalInstall, Mode=TwoWay}"
                                         GroupName="InstallMode">
                                <ToolTipService.ToolTip>
                                    <TextBlock TextWrapping="Wrap" MaxWidth="300"
                                               Text="Silent install — driver only, no NVIDIA UI. Faster and lighter. Progress tracked in NVLite." />
                                </ToolTipService.ToolTip>
                            </RadioButton>
                            <RadioButton Content="Express (NVIDIA Installer)"
                                         GroupName="InstallMode">
                                <ToolTipService.ToolTip>
                                    <TextBlock TextWrapping="Wrap" MaxWidth="300"
                                               Text="Opens the full NVIDIA installer with its own UI. Choose this if minimal install fails or you need component selection." />
                                </ToolTipService.ToolTip>
                            </RadioButton>

                            <!-- Extra options -->
                            <StackPanel Spacing="6" Margin="0,4,0,0">
                                <CheckBox Content="Clean install"
                                          IsChecked="{x:Bind ViewModel.CleanInstall, Mode=TwoWay}"
                                          ToolTipService.ToolTip="Removes the old driver completely before installing. Resets NVIDIA settings and registry entries." />
                                <CheckBox Content="Clear shader cache"
                                          IsChecked="{x:Bind ViewModel.ClearShaderCache, Mode=TwoWay}"
                                          ToolTipService.ToolTip="Deletes pre-compiled GPU shaders. Games may stutter briefly on first launch while shaders recompile." />
                            </StackPanel>

                            <!-- Install button -->
                            <Button Content="Install Driver"
                                    Command="{x:Bind ViewModel.LaunchInstallerCommand}"
                                    Style="{StaticResource AccentButtonStyle}" />
                        </StackPanel>

                        <!-- Install progress (indeterminate) -->
                        <StackPanel Spacing="6"
                                    Visibility="{x:Bind ViewModel.IsInstalling, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <ProgressBar IsIndeterminate="True" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                                           Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button Grid.Column="1" Content="Cancel"
                                        Command="{x:Bind ViewModel.CancelInstallCommand}" />
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Driver Rollback -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20"
                        Visibility="{x:Bind ViewModel.HasRollback, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Driver Rollback" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="Download the previous driver version to revert if you experience issues with the current driver." />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock VerticalAlignment="Center">
                                <Run Text="Previous version: " Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Run Text="{x:Bind ViewModel.RollbackVersion, Mode=OneWay}" FontWeight="SemiBold" />
                            </TextBlock>
                            <Button Content="Download Previous Version"
                                    Command="{x:Bind ViewModel.RollbackDriverCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Version History -->
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="20"
                        Visibility="{x:Bind ViewModel.HasVersionHistory, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Version History" Style="{StaticResource SubtitleTextBlockStyle}" />
                        <ListView ItemsSource="{x:Bind ViewModel.VersionHistory, Mode=OneWay}"
                                  SelectionMode="None" IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="drivers:DriverReleaseInfo">
                                    <Grid Padding="0,8" ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{x:Bind Version}" FontWeight="SemiBold" />
                                                <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                                        CornerRadius="4" Padding="6,2" VerticalAlignment="Center"
                                                        Visibility="{x:Bind IsInstalled, Converter={StaticResource BoolToVisibility}}">
                                                    <TextBlock Text="Installed"
                                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                                </Border>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind ReleaseDate}"
                                                           Style="{StaticResource CaptionTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <HyperlinkButton Content="Release Notes"
                                                                 NavigateUri="{x:Bind DetailsUrl}"
                                                                 Padding="0"
                                                                 Style="{StaticResource TextBlockButtonStyle}" />
                                            </StackPanel>
                                        </StackPanel>
                                        <Border Grid.Column="1" Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                                CornerRadius="4" Padding="8,2" VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{x:Bind Branch}"
                                                       Style="{StaticResource CaptionTextBlockStyle}" />
                                        </Border>
                                        <Button Grid.Column="2" Content="Download" Tag="{x:Bind DownloadUrl}"
                                                Click="VersionDownload_Click"
                                                VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Status -->
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,0,0,8" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
