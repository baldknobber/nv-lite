<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="NVLite.App.Views.ProfilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:profiles="using:NVLite.Core.Profiles"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="Driver Profiles" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center" />
            <AutoSuggestBox Grid.Column="1" PlaceholderText="Search profiles..."
                            QueryIcon="Find" Margin="24,0"
                            TextChanged="{x:Bind ViewModel.OnSearchTextChanged}" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button Content="New Profile" Click="NewProfile_Click">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="N" />
                    </Button.KeyboardAccelerators>
                </Button>
                <Button Content="Export" Command="{x:Bind ViewModel.ExportCommand}" />
                <Button Content="Import" Command="{x:Bind ViewModel.ImportCommand}" />
            </StackPanel>
        </Grid>

        <!-- Educational InfoBar -->
        <InfoBar Grid.Row="1" IsOpen="True" IsClosable="True"
                 Severity="Informational"
                 Title="About driver profiles"
                 Message="Driver profiles control how NVIDIA renders each game — things like VSync, anti-aliasing, and power management. You can create per-game profiles or edit the global base profile."
                 Margin="0,0,0,12" />

        <!-- Main content -->
        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Profile List -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <ListView ItemsSource="{x:Bind ViewModel.FilteredProfiles, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedProfile, Mode=TwoWay}"
                          SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="profiles:ProfileInfo">
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind SettingCount}" />
                                            <Run Text="settings" />
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                                <Border Grid.Column="1" VerticalAlignment="Center"
                                        Visibility="{Binding IsPredefined, Converter={StaticResource BoolToVisibility}}"
                                        Background="{ThemeResource SystemFillColorNeutralBackgroundBrush}"
                                        CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="Built-in" Style="{StaticResource CaptionTextBlockStyle}" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Settings Grid -->
            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind ViewModel.SelectedProfileName, Mode=OneWay}"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <Button Grid.Column="1" Content="Delete" Click="DeleteProfile_Click"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                Visibility="{x:Bind ViewModel.CanDeleteSelectedProfile, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>

                    <ListView Grid.Row="1"
                              ItemsSource="{x:Bind ViewModel.SelectedProfileSettings, Mode=OneWay}"
                              SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="profiles:ProfileSettingInfo">
                                <Grid ColumnSpacing="16" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBox Grid.Column="1" Text="{x:Bind ValueString}"
                                             Tag="{x:Bind Id}"
                                             LostFocus="SettingValue_LostFocus"
                                             VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Save bar -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0"
                                Visibility="{x:Bind ViewModel.HasUnsavedChanges, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <Button Content="Save Changes" Style="{StaticResource AccentButtonStyle}"
                                Command="{x:Bind ViewModel.SaveChangesCommand}" />
                        <TextBlock Text="You have unsaved changes"
                                   VerticalAlignment="Center"
                                   Foreground="{ThemeResource SystemFillColorCautionBrush}"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <StackPanel Grid.Row="3" Margin="0,8,0,0" Spacing="8">
            <!-- Community Profiles -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                      Expanding="CommunityExpander_Expanding">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE774;" FontSize="16" />
                        <TextBlock Text="Community Profiles" FontWeight="SemiBold" />
                    </StackPanel>
                </Expander.Header>
                <StackPanel Spacing="8">
                    <TextBlock Text="Curated profiles shared by the NVLite community on GitHub."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <ListView ItemsSource="{x:Bind ViewModel.CommunityProfiles, Mode=OneWay}"
                              SelectionMode="None" MaxHeight="300">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="profiles:CommunityProfileEntry">
                                <Grid Padding="0,6" ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold">
                                            <Run Text="{x:Bind GameName}" />
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="by " /><Run Text="{x:Bind Contributor}" />
                                            <Run Text=" — " /><Run Text="{x:Bind Description}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <HyperlinkButton Grid.Column="1" Content="View on GitHub"
                                                     NavigateUri="https://github.com/baldknobber/nv-lite/tree/main/community-profiles"
                                                     VerticalAlignment="Center" />
                                    <Button Grid.Column="2" Content="Apply" Tag="{x:Bind FileName}"
                                            Click="ApplyCommunityProfile_Click"
                                            VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock Text="No community profiles available yet. Contribute yours on GitHub!"
                               Visibility="{x:Bind ViewModel.HasCommunityProfiles, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Expander>

            <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </Grid>
</Page>
